# Dashboard → service endpoints (the three control surfaces).
# Defaults target the local docker `app` stack; override if the services run
# elsewhere. Copy to `.env.local` (gitignored) to customize.
# The services must allow this dashboard's origin via CORS_ORIGINS (see docker/.env).
VITE_INGESTION_URL=http://localhost:3001
VITE_STORAGE_URL=http://localhost:3002
VITE_ANALYTICS_URL=http://localhost:3003
