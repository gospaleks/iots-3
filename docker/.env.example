# Copy to docker/.env and adjust. The .env file is gitignored.
# See docs/REQUIREMENTS.md §5 for the full per-service variable reference.

# ─── Broker selection ──────────────────────────────────────────────
# Drives the runtime adapter in every service. Pair with the matching
# compose profile:  docker compose --profile <mqtt|kafka> up -d
BROKER_TYPE=mqtt                # mqtt | kafka

# Generic broker endpoint consumed by the adapters.
# MQTT   -> host: mosquitto  port: 1883
# Kafka  -> host: kafka      port: 9092
BROKER_HOST=mosquitto
BROKER_PORT=1883
TOPIC=sensors/telemetry         # kafka uses: sensor-telemetry

# ─── Database (TimescaleDB) ────────────────────────────────────────
POSTGRES_USER=iot
POSTGRES_PASSWORD=iot
POSTGRES_DB=iotdb
DATABASE_URL=postgresql://iot:iot@timescaledb:5432/iotdb

# ─── Kafka (KRaft) extras ──────────────────────────────────────────
# Stable cluster id so the data volume survives restarts. Generate a new one
# with: kafka-storage random-uuid   (any 22-char base64 id works).
KAFKA_CLUSTER_ID=5L6g3nShT-eMCtK--X86sw
KAFKA_NUM_PARTITIONS=1          # 3 / 6 for Scenario A partition-scaling tests

# ─── Dev tooling (profile: tools — dev only, off the benchmark path) ──
KAFKA_UI_PORT=8080              # kafbat/kafka-ui web UI → http://localhost:<port>

# ─── Optional dashboard (off the benchmark path) ───────────────────
# CORS allowlist for the three services' /stats /health endpoints so the
# browser dashboard can read them. Comma-separated origins; unset/"*" ⇒
# reflect any origin (local demo default). Only affects HTTP response
# headers — zero effect on the broker data path or measurements.
CORS_ORIGINS=*                  # e.g. http://localhost:5173 to lock it down

# ─── Ingestion Service (§5.1) ──────────────────────────────────────
NUM_DEVICES=100
MESSAGES_PER_SECOND=10          # PER DEVICE → baseline total = NUM_DEVICES × this
BURST_TARGET_RATE=5000          # TOTAL fleet rate during a burst (Scenario C)
DATA_SOURCE=replay              # replay (from CSV) | random
DATASET_PATH=/data/iot_telemetry_data.csv
REPLAY_SAMPLE_SIZE=10000        # rows sampled per device profile at startup (replay)
INGESTION_PORT=3001             # control surface: GET /health /stats, POST /burst
QOS_LEVEL=1                     # MQTT only: 0 | 1 | 2
MQTT_CLEAN_SESSION=true         # MQTT only: false ⇒ persistent session (Scenario B subscriber outage)
MQTT_KEEPALIVE_SEC=60           # MQTT only: low (e.g. 10) ⇒ broker detects a dead client fast (Scenario B)
KAFKA_ACKS=1                    # Kafka only: 0 | 1 | all

# ─── Storage Service (§5.2) ────────────────────────────────────────
WRITE_MODE=BATCH                # DIRECT | BATCH
BATCH_SIZE=500
FLUSH_INTERVAL_MS=1000
STORAGE_PORT=3002               # control surface: GET /health /stats

# ─── Analytics Service (§5.3) ──────────────────────────────────────
WINDOW_SIZE_SEC=10
ALERT_THRESHOLD=50.0            # avg temp (°F) over a window → [ALERT] if exceeded
ANALYTICS_GROUP_ID=iots-analytics  # Kafka: consumer group B (distinct from storage)
ANALYTICS_PORT=3003             # control surface: GET /health /stats
