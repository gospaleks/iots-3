# Copy to docker/.env and adjust. The .env file is gitignored.
# Project 3 is MQTT-only (BROKER_TYPE=mqtt).

# ─── Broker selection ──────────────────────────────────────────────
# Drives the runtime adapter in every service. Pair with the mqtt profile:
#   docker compose --profile mqtt up -d
BROKER_TYPE=mqtt                # mqtt

# Generic broker endpoint consumed by the adapters (MQTT → mosquitto:1883).
BROKER_HOST=mosquitto
BROKER_PORT=1883
TOPIC=sensors/telemetry         # raw telemetry topic (RAW_TOPIC)

# ─── Database (TimescaleDB) ────────────────────────────────────────
POSTGRES_USER=iot
POSTGRES_PASSWORD=iot
POSTGRES_DB=iotdb
DATABASE_URL=postgresql://iot:iot@timescaledb:5432/iotdb

# ─── Web app (optional) ────────────────────────────────────────────
# CORS allowlist for the services' HTTP endpoints so a browser web app can read
# them. Comma-separated origins; unset/"*" ⇒ reflect any origin (local default).
# Only affects HTTP response headers — zero effect on the broker data path.
CORS_ORIGINS=*                  # e.g. http://localhost:5173 to lock it down

# ─── Ingestion Service ─────────────────────────────────────────────
# Demo default: 3 devices maps 1:1 onto the 3 dataset profiles with bare MAC ids
# (device.ts only appends a -N suffix when NUM_DEVICES > 3). Bump NUM_DEVICES
# (e.g. 100) for a scale/throughput demo — ids then become <mac>-<i>.
NUM_DEVICES=3
MESSAGES_PER_SECOND=10          # PER DEVICE → baseline total = NUM_DEVICES × this
BURST_TARGET_RATE=150           # TOTAL fleet rate during a burst (POST /burst)
DATA_SOURCE=replay              # replay (from CSV) | random
DATASET_PATH=/data/iot_telemetry_data.csv
REPLAY_SAMPLE_SIZE=10000        # rows sampled per device profile at startup (replay)
INGESTION_PORT=3001             # control surface: GET /health /stats, POST /burst
QOS_LEVEL=1                     # MQTT: 0 | 1 | 2
MQTT_CLEAN_SESSION=true         # MQTT: false ⇒ persistent session (offline subscriber buffering)
MQTT_KEEPALIVE_SEC=60           # MQTT: low ⇒ broker detects a dead client fast

# ─── Storage Service ───────────────────────────────────────────────
WRITE_MODE=BATCH                # DIRECT | BATCH
BATCH_SIZE=500
FLUSH_INTERVAL_MS=1000
STORAGE_PORT=3002               # control surface: GET /health /stats

# ─── Analytics Service ─────────────────────────────────────────────
WINDOW_SIZE_SEC=10
ALERT_THRESHOLD=50.0            # avg temp (°F) over a window → [ALERT] if exceeded
ANALYTICS_PORT=3003             # control surface: GET /health /stats

# ─── eKuiper window (Phase 1) ──────────────────────────────────────
# WINDOW_SIZE stays 10 (the MaaS model was trained on 10s aggregates).
# Overlapping-window demo: WINDOW_TYPE=hopping WINDOW_STEP=5, then re-provision:
#   docker compose ... up -d --force-recreate ekuiper-provision
# hopping/session REQUIRE WINDOW_STEP (provision.sh fails fast without it).
# WINDOW_TYPE=sliding emits one event PER incoming message (flood by design).
WINDOW_TYPE=tumbling            # tumbling|hopping|sliding|session|count
WINDOW_UNIT=ss                  # ms|ss|mi|hh|dd
WINDOW_SIZE=10
# hop (hopping, required) | delay (sliding) | maxDuration (session, required) | interval (count)
# NOTE: keep this comment on its own line. Compose's dotenv parser only strips an inline
# `# ...` when the key HAS a value — on an empty key the comment becomes the value.
WINDOW_STEP=

# ─── eKuiper thresholds (Phase 1/6) ────────────────────────────────
# Demo-calibrated to the 3 device profiles so each rule lights up a different
# device (see shared/thresholds.md): 1c:bf (~26.9°C) → SUSTAINED_HIGH_TEMP;
# b8:27 (~22.5°C, ~50% humidity) → HEAT_DRYING + the CO spikes; 00:0f stays quiet.
TEMP_HIGH=22.0
CO_HIGH=0.00508
HUMIDITY_LOW=55.0
SMOKE_HIGH=0.030
SUSTAINED_TEMP=25.0
RING_BUFFER_SIZE=200            # web-app history cap (Analytics /api/* snapshots + socket replay)
EVENTS_TOPIC=sensors/events     # eKuiper sink → Analytics

# ─── Analytics ↔ MaaS (Phase 5) ────────────────────────────────────
MAAS_URL=http://maas:8000
MAAS_TIMEOUT_MS=1000
LAG_WINDOWS=4                   # feature-vector depth; must match train.py + MaaS features.py

# ─── Analytics Socket.IO / web transport (Phase 5/7) ───────────────
SOCKETIO_CORS_ORIGINS=*         # reuse CORS_ORIGINS if already present

# ─── MaaS (Phase 4) ────────────────────────────────────────────────
MODEL_PATH=/models/model.joblib
MAAS_PORT=8000
